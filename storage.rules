rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Profile photos — everyone can view, only the owner can upload/replace.
    // Max file size: 5 MB. Must be an image.
    match /profile-photos/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Speaker resource folder — any signed-in user can read (so the library
    // is visible in-app), but only the owner of the folder can upload, and
    // only the owner or an admin can delete. Admin checks happen in the
    // Firestore layer when the resource doc is deleted; Storage simply
    // scopes write access to the uploading user.
    // Max file size: 20 MB.
    match /resources/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 20 * 1024 * 1024;
    }

    // Default deny — anything else is blocked.
  }
}
